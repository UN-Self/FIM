# FIM Eval 配置 — 复制本文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会被提交

# 必填：被测 DeepSeek API key
DEEPSEEK_API_KEY=sk-xxxxxxxx

# 可选：模型名（默认 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# 可选：Layer3 裁判（任意 OpenAI 兼容端点，三者留空则 Layer3 自动 skip）
# JUDGE_BASE_URL=https://api.openai.com
# JUDGE_API_KEY=sk-xxxxxxxx
# JUDGE_MODEL=gpt-4o-mini

# 可选：数据集 synthetic / fim-self / all（默认 all）
# EVAL_DATASET=synthetic
