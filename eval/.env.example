# FIM Eval 配置 — 复制本文件为 .env 并填入真实值
# .env 已加入 .gitignore，不会被提交

# 必填：被测 DeepSeek API key
DEEPSEEK_API_KEY=sk-xxxxxxxx

# 可选：模型名（默认 deepseek-v4-flash）
# DEEPSEEK_MODEL=deepseek-v4-flash

# 可选：Layer3 裁判（任意 OpenAI 兼容端点，三者留空则 Layer3 自动 skip）
# JUDGE_BASE_URL=https://api.openai.com
# JUDGE_API_KEY=sk-xxxxxxxx
# JUDGE_MODEL=gpt-4o-mini

# 每个样本矩阵独立生成次数，以及对固定 completion / 盲测对进行的 judge 次数。
# 默认均为 3；本地快速调试可全部设为 1。
# EVAL_WRITER_RUNS=3
# EVAL_JUDGE_RUNS=3
# EVAL_PAIRWISE_JUDGE_RUNS=3

# 可选：数据集 synthetic / fim-self / all（默认 all）
# EVAL_DATASET=synthetic

# 默认运行 baseline、CodeGraph context、CodeGraph + intent planner 三组对照。
# 可选值：baseline,codegraph,codegraph-planner
# EVAL_MATRICES=baseline,codegraph,codegraph-planner

# CodeGraph 每次查询最多使用的图节点数（默认 12）
# CODEGRAPH_MAX_NODES=12

# 可选：使用 Engine ChainV2（默认 false，走 ChainV1）
# EVAL_USE_ENGINE_CHAIN=false

# 可选：意图 planner。默认复用 DEEPSEEK_API_KEY / DEEPSEEK_MODEL，
# 并调用 https://api.deepseek.com/chat/completions。
# INTENT_BASE_URL=https://api.deepseek.com/chat/completions
# INTENT_API_KEY=sk-xxxxxxxx
# INTENT_MODEL=deepseek-v4-flash
# INTENT_MAX_CONTEXT_CHARS=24000

# 可选：FIM 日志等级（扩展与 eval 共用）。
# 取值 error / warn / info / debug / trace，默认 info。
# - info：生命周期 + 错误（eval 默认静音请求 dump 与 formatter 跟踪）
# - debug：追加 completion formatter 各步骤跟踪
# - trace：追加 FIM 请求全量 dump（API key 始终脱敏，不会泄漏）
# 优先级：扩展内 fim.logLevel 设置 > 此环境变量 > 默认 info。
# FIM_LOG_LEVEL=info
